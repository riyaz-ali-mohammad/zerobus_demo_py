{
  "datasets": [
    {
      "name": "freshness",
      "displayName": "Freshness + latency",
      "queryLines": [
        "SELECT\n",
        "  COUNT_IF(ingestion_time >= current_timestamp() - INTERVAL 5 MINUTES) AS rows_total,\n",
        "  MAX(ingestion_time) AS last_ingested_at,\n",
        "  ROUND((unix_timestamp(current_timestamp()) - unix_timestamp(MAX(ingestion_time))), 2) AS seconds_since_last_row,\n",
        "  ROUND(percentile_approx(unix_timestamp(ingestion_time) - unix_timestamp(event_time), 0.50), 3) AS e2e_latency_p50_s,\n",
        "  ROUND(percentile_approx(unix_timestamp(ingestion_time) - unix_timestamp(event_time), 0.95), 3) AS e2e_latency_p95_s\n",
        "FROM karthik_auto_validator_1.iot.sensor_readings_clean"
      ]
    },
    {
      "name": "throughput",
      "displayName": "Throughput rollups",
      "queryLines": [
        "SELECT\n",
        "  COUNT(CASE WHEN ingestion_time >= current_timestamp() - INTERVAL 1  MINUTES THEN 1 END) AS rows_1m,\n",
        "  COUNT(CASE WHEN ingestion_time >= current_timestamp() - INTERVAL 5  MINUTES THEN 1 END) AS rows_5m,\n",
        "  COUNT(CASE WHEN ingestion_time >= current_timestamp() - INTERVAL 60 MINUTES THEN 1 END) AS rows_60m,\n",
        "  ROUND(COUNT(CASE WHEN ingestion_time >= current_timestamp() - INTERVAL 1 MINUTES THEN 1 END) / 60.0, 1) AS events_per_second_1m\n",
        "FROM karthik_auto_validator_1.iot.sensor_readings_clean"
      ]
    },
    {
      "name": "minute_trends",
      "displayName": "Per-minute trends",
      "queryLines": [
        "SELECT window_start, site, sensor_type, avg_value, n_readings, n_alerts\n",
        "FROM karthik_auto_validator_1.iot.sensor_minute_agg\n",
        "WHERE window_start >= current_timestamp() - INTERVAL 30 MINUTES"
      ]
    },
    {
      "name": "anomalies_recent",
      "displayName": "Recent anomalies",
      "queryLines": [
        "SELECT event_time, device_id, site, sensor_type, reading_value, unit, status\n",
        "FROM karthik_auto_validator_1.iot.sensor_anomalies\n",
        "WHERE event_time >= current_timestamp() - INTERVAL 30 MINUTES\n",
        "ORDER BY event_time DESC\n",
        "LIMIT 100"
      ]
    },
    {
      "name": "anomalies_by_sensor",
      "displayName": "Anomalies by sensor",
      "queryLines": [
        "SELECT sensor_type, COUNT(*) AS n_anomalies\n",
        "FROM karthik_auto_validator_1.iot.sensor_anomalies\n",
        "WHERE event_time >= current_timestamp() - INTERVAL 30 MINUTES\n",
        "GROUP BY sensor_type\n",
        "ORDER BY n_anomalies DESC"
      ]
    }
  ],
