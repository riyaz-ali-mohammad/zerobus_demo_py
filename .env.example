# Copy to .env and populate. The setup CLI will rewrite this file when you run
# `python -m setup.cli register-sp` (preserving the values you put here).
#
# How to get these:
#   1. Workspace UI > Settings > Identity and access > Service principals
#   2. Create a new SP (or pick an existing one you can manage)
#   3. Open the SP > "Generate secret" — copy the secret immediately (one-time)
#   4. ZB_CLIENT_ID = the SP's `applicationId` (UUID), NOT the numeric `id`
#   5. ZB_SP_ID    = the numeric id (only needed if you want `cleanup` to
#                    delete the SP for you)

DATABRICKS_HOST=https://your-workspace.cloud.databricks.com
ZB_CLIENT_ID=
ZB_CLIENT_SECRET=
ZB_TABLE_FQN=karthik_auto_validator_1.iot.sensor_readings
ZB_SP_ID=
